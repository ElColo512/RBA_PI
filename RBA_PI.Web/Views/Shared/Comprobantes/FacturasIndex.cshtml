@model FacturasIndexViewModel

<div class="container py-4">

    <div class="d-flex flex-wrap gap-2 mb-4">
        <a class="btn btn-primary" asp-controller="FacturasConceptos" asp-action="Index">Facturas de Concepto</a>
        <a class="btn btn-primary" asp-controller="FacturasRemitos" asp-action="Index">Facturas Remitos sin/OC</a>
        <a class="btn btn-primary" asp-controller="ImportacionDatos" asp-action="Index" asp-route-returnUrl="@Model.ReturnUrl">Importar Datos</a>
        <a class="btn btn-primary" asp-controller="AnalisisDatos" asp-action="Index">Análisis de Datos</a>
        <a class="btn btn-primary" asp-controller="Home" asp-action="Index">Menú Principal</a>
    </div>

    <div class="mb-3">
        <span class="fw-bold">
            @Model.Config.Titulo
        </span>
    </div>

    <form class="d-flex flex-wrap align-items-center mb-4 gap-3">
        <div class="d-flex align-items-center">
            <label class="form-label me-2 mb-0" style="min-width: 200px;">Visualizar Facturas desde el:</label>
            <input type="date" asp-for="Filtros.Desde" id="filtroDesde" class="form-control form-control-sm" />
        </div>

        <div class="d-flex align-items-center">
            <label class="form-label me-2 mb-0 w-50">Hasta el:</label>
            <input type="date" asp-for="Filtros.Hasta" id="filtroHasta" class="form-control form-control-sm" />
        </div>

        <div class="d-flex align-items-center">
            <label class="form-label me-2 mb-0" style="min-width: 220px;">Estados de los comprobantes:</label>
            <select asp-for="Filtros.EstadoId" asp-items="Model.Filtros.Estados" id="filtroEstado" class="form-select form-select-sm"></select>
        </div>

        <button type="button" id="btnBuscar" class="btn btn-primary btn-sm">Buscar</button>
        @if (Model.Config.MostrarBotonExcel)
        {
            <button type="button" id="btnExportarExcel" class="btn btn-success btn-sm">Exportar a Excel</button>
        }
    </form>

    <table id="facturasTable" class="table table-striped table-bordered w-100">
        <thead>
            <tr>
                <th style="width:8%">Fecha</th>
                <th style="width:29%">Proveedor</th>
                <th style="width:11%">CUIT</th>
                <th style="width:15%">Nro. Factura</th>
                <th style="width:12%">Importe</th>
                <th style="width:15%">Estado</th>
                <th style="width:10%">Acciones</th>
            </tr>
        </thead>
    </table>
</div>

@section Scripts {
    <script>
        const verificarUrlBase = '@Model.Config.UrlVerificar';
        let table;
        $(document).ready(function () {
            table = $('#facturasTable').DataTable({
                stateSave: true,
                processing: true,
                serverSide: false,
                responsive: true,
                ajax: {
                    url: '@Url.Action("Buscar", "FacturasConceptos")',
                    data: function (d) {
                        d.Desde = $('#filtroDesde').val();
                        d.Hasta = $('#filtroHasta').val();
                        d.EstadoId = $('#filtroEstado').val();
                    }
                },
                columns: [
                    { data: 'fecha' },
                    { data: 'razonSocial' },
                    { data: 'cuit' },
                    { data: 'comprobante' },
                    { data: 'importeTotal', className: 'text-end' },
                    { data: 'estado' },
                    {
                        data: 'id',
                        orderable: false,
                        render: function (data, type, row) {
                            const esNotaCredito = row.comprobante?.startsWith("N/C");
                            const botonesHTML = {
                                procesar: `<button class="btn btn-sm btn-primary btn-procesar" data-id="${row.id}" title="Procesar en Tango"><i class="bi bi-arrow-right-circle"></i></button>`,
                                descartar: `<button class="btn btn-sm btn-danger btn-descartar" data-id="${row.id}" title="Descartar"><i class="bi bi-x-circle"></i></button>`,
                                cargaDirecta: `<button class="btn btn-sm btn-success btn-carga-directa" data-id="${row.id}" data-interno="${row.interno}" title="Carga directa en Tango"><i class="bi bi-cloud-upload"></i></button>`,
                                marcarPendiente: `<button class="btn btn-sm btn-secondary btn-pendiente" data-id="${row.id}" title="Marcar como pendiente"><i class="bi bi-hourglass-split"></i></button>`
                            };
                            const botonesPorEstado = {
                                "Pendiente": ["procesar", "descartar", "cargaDirecta"],
                                "Rechazada": ["marcarPendiente"],
                                "Carga Directa en Tango": ["procesar", "marcarPendiente"],
                                "Exp. a Tango": ["marcarPendiente"]
                            };
                              let botonesPermitidos = botonesPorEstado[row.estado] || ["marcarPendiente"];

                              if (esNotaCredito) {
                                  botonesPermitidos = botonesPermitidos.filter(b => b !== "procesar");
                              }

                              const botones = botonesPermitidos.map(b => botonesHTML[b]).join('');

                            return `<div class="d-flex gap-1">${botones}</div>`;
                        }
                    }
                ],
                language: {url: 'https://cdn.datatables.net/plug-ins/2.3.6/i18n/es-AR.json'},
                pageLength: 100,
                lengthMenu: [
                    [10, 25, 50, 100, 250, 500, 1000],
                    [10, 25, 50, 100, 250, 500, 1000]
                ]
            });

            $('#btnBuscar').on('click', function () {
                const filtros = {
                    desde: $('#filtroDesde').val(),
                    hasta: $('#filtroHasta').val(),
                    estadoId: $('#filtroEstado').val()
                };

                fetch('@Url.Action("GuardarFiltros", "FacturasConceptos")', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(filtros)
                });
                table.ajax.reload();
            });
        });

        const btnExportar = document.getElementById("btnExportarExcel");
        if (btnExportar) {
            btnExportar.addEventListener("click", async () => {
                const desde = document.getElementById("filtroDesde").value;
                const hasta = document.getElementById("filtroHasta").value;
                const estadoId = document.getElementById("filtroEstado").value;
                const url = `/FacturasConceptos/ExportarExcel?desde=${desde}&hasta=${hasta}&estadoId=${estadoId}`;
                const response = await fetch(url);

                if (!response.ok) {
                    const error = await response.json();
                    showToast(error.message ?? "No hay datos para exportar", "warning");
                    return;
                }

                const blob = await response.blob();
                const downloadUrl = window.URL.createObjectURL(blob);
                const a = document.createElement("a");
                a.href = downloadUrl;
                a.download = "Facturas_de_Conceptos.xlsx";
                document.body.appendChild(a);
                a.click();
                a.remove();
                window.URL.revokeObjectURL(downloadUrl);
            });
        }

        document.addEventListener("click", e => {
            const btnProcesar = e.target.closest(".btn-procesar");
            if (btnProcesar) {
                preparar(`${verificarUrlBase}/${btnProcesar.dataset.id}`);
                return;
            }

            const btnDescartar = e.target.closest(".btn-descartar");
            if (btnDescartar) {
                descartar(btnDescartar.dataset.id);
                return;
            }

            const btnCarga = e.target.closest(".btn-carga-directa");
            if (btnCarga) {
                cargaDirecta(
                    btnCarga.dataset.id,
                    btnCarga.dataset.interno,
                    btnCarga
                );
                return;
            }

            const btnPendiente = e.target.closest(".btn-pendiente");
            if (btnPendiente) {
                marcarPendiente(btnPendiente.dataset.id);
                return;
            }
        });

        async function preparar(url) {
            try{
                const res = await fetch(url);
                const data = await res.json();

                if (!res.ok) {
                    showToast(data.message, data.type ?? "warning");
                    if (data?.reload) {
                        table.ajax.reload(null, false);
                    }
                    return;
                }

                window.location.href = data.redirectUrl;
            } catch (e) {
                showToast("Error inesperado al preparar el comprobante", "danger");
            }
        }

        function marcarPendiente(id) {
            postJson('@Url.Action("Pendiente", "FacturasConceptos")',
            { idComprobante: id },
            {
                successType: 'warning',
                onSuccess: () => table.ajax.reload(null, false)
            }
            );
        }

        function cargaDirecta(id, interno, btn) {
            postJson('@Url.Action("CargaDirecta", "FacturasConceptos")',
            { idComprobante: id },
            {
                successType: 'success',
                onSuccess: () => table.ajax.reload(null, false)
            }
            );
        }

        function descartar(id) {
            postJson('@Url.Action("Descartar", "FacturasConceptos")',
            { idComprobante: id },
            {
                successType: 'danger',
                onSuccess: () => table.ajax.reload(null, false)
            }
            );
        }
    </script>
}
