@model AnalisisDatosViewModel

<div class="container py-4">

    <div class="d-flex flex-wrap gap-2 mb-4">
        <a class="btn btn-primary" asp-controller="FacturasConceptos" asp-action="Index">Facturas de Concepto</a>
        <a class="btn btn-primary" asp-controller="FacturasRemitos" asp-action="Index">Facturas Remitos sin/OC</a>
        <a class="btn btn-primary" asp-controller="ImportacionDatos" asp-action="Index" asp-route-returnUrl="@Url.Action("Index", "AnalisisDatos")">Importar Datos</a>
        <a class="btn btn-primary" asp-controller="AnalisisDatos" asp-action="Index">Análisis de Datos</a>
        <a class="btn btn-primary" asp-controller="Home" asp-action="Index">Menú Principal</a>
    </div>

    <div class="mb-3 fw-bold">
        Análisis de Datos. Comparación de facturas desde el portal de integración respecto a Tango.
    </div>

    <form class="d-flex flex-wrap align-items-center mb-4 gap-3">
        <div class="d-flex align-items-center">
            <label class="form-label me-2 mb-0" style="min-width: 200px;">Visualizar Facturas desde el:</label>
            <input type="date" asp-for="Desde" class="form-control form-control-sm" />
        </div>

        <div class="d-flex align-items-center">
            <label class="form-label me-2 mb-0 w-50">Hasta el:</label>
            <input type="date" asp-for="Hasta" class="form-control form-control-sm" />
        </div>

        <button type="button" id="btnBuscar" class="btn btn-primary btn-sm">
            Analizar desde ARCA
        </button>
    </form>

    <table id="tablaAnalisis" class="table table-striped table-bordered w-100">
        <thead>
            <tr>
                <th style="width:8%">Fecha</th>
                <th style="width:29%">Proveedor</th>
                <th style="width:11%">CUIT</th>
                <th style="width:15%">Nro. Factura</th>
                <th class="text-end" style="width:12%">Importe Total</th>
                <th style="width:15%">Estado</th>
                <th style="width:5%">Nro. Int. Tango</th>
                <th style="width:5%">Acciones</th>
            </tr>
        </thead>
    </table>
</div>

@section Scripts {
    <script>
        let table;

        $(document).ready(function () {
            table = $('#tablaAnalisis').DataTable({
                processing: true,
                serverSide: false,
                responsive: true,
                ajax: {
                    url: '@Url.Action("Buscar", "AnalisisDatos")',
                    data: function (d) {
                        d.desde = $('#Desde').val();
                        d.hasta = $('#Hasta').val();
                    }
                },
                columns: [
                    { data: 'fecha' },
                    { data: 'razonSocial' },
                    { data: 'cuit' },
                    { data: 'comprobante' },
                    { data: 'importeTotal', className: 'text-end' },
                    { data: 'estado' },
                    { data: 'interno', className: 'text-end' },
                    {
                        data: 'id',
                        orderable: false,
                        className: 'text-center',
                        render: function (data, type, row) {
                            if (row.estado === 'Pendiente' && row.interno) {
                                return `<div class="d-flex justify-content-center gap-1">
                                <button class="btn btn-success btn-sm btn-carga-directa" title="Carga directa en Tango" data-id="${row.id}" data-interno="${row.interno}">
                                <i class="bi bi-cloud-upload"></i>
                                </button>
                                </div>`;
                            }
                            return '';
                        }
                    }
                ],
                language: {url: 'https://cdn.datatables.net/plug-ins/2.3.6/i18n/es-AR.json'},
                pageLength: 100,
                lengthMenu: [
                    [10, 25, 50, 100, 250, 500, 1000],
                    [10, 25, 50, 100, 250, 500, 1000]
                ]
            });

            $('#btnBuscar').on('click', function () {
                const filtros = {
                    desde: $('#Desde').val(),
                    hasta: $('#Hasta').val(),
                };

                fetch('@Url.Action("GuardarFiltros", "FacturasConceptos")', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(filtros)
                });
                table.ajax.reload();
            });
        });

        document.addEventListener("click", e => {
            const btn = e.target.closest(".btn-carga-directa");
            if (!btn) return;

            cargaDirecta(
                btn.dataset.id,
                btn.dataset.interno,
                btn
            );
        });

        function cargaDirecta(id, interno, btn) {
            postJson('@Url.Action("CargaDirecta", "AnalisisDatos")',
            {
                idComprobante: id,
                interno: interno
            },
            {
                onSuccess: () => {
                    const dtRow = table.row($(btn).closest('tr'));
                    const rowData = dtRow.data();
                        rowData.estado = `Carga Directa en Tango (${interno})`;
                        dtRow.data(rowData).invalidate().draw(false);
                }
            });
        }
    </script>
}
