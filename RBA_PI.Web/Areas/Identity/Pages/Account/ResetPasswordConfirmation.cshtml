@page
@model ResetPasswordConfirmationModel
@{
    Layout = "/Views/Shared/_LayoutEmpty.cshtml";
    ViewData["Title"] = "Contraseña restablecida";
}

<div class="d-flex justify-content-center align-items-center vh-100">
    <div class="card shadow-lg text-center identity-card" style="max-width: 420px;">
        <div class="card-body p-4">
            <div class="mb-3">
                <i class="bi bi-check-circle-fill text-success" style="font-size: 3rem;"></i>
            </div>

            <h4 class="mb-3">¡Contraseña restablecida!</h4>

            <p class="text-muted mb-4">
                Su contraseña ha sido restablecida correctamente.
                Ya puede ingresar al sistema con su nueva contraseña.
            </p>

            <div class="d-grid">
                <a asp-page="./Login" class="btn btn-primary">Iniciar sesión</a>
            </div>
        </div>
    </div>
</div>
