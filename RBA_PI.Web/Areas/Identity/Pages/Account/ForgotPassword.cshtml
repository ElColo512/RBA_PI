@page
@model ForgotPasswordModel
@{
    Layout = "/Views/Shared/_LayoutEmpty.cshtml";
    ViewData["Title"] = "Recuperar contraseña";
}

<div class="d-flex justify-content-center align-items-center vh-100">
    <div class="card shadow-lg identity-card" style="max-width: 420px;">
        <div class="card-body p-4">
            <div class="text-center mb-4">
                <i class="bi bi-lock-fill text-warning" style="font-size: 3rem;"></i>
                <h4 class="mt-3">¿Olvidaste tu contraseña?</h4>

                <p class="text-muted small mb-0">
                    Ingresá tu email y CUIT para recibir el enlace de recuperación.
                </p>
            </div>

            <form method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>
                <div class="form-floating mb-3">
                    <input asp-for="Input.Email" class="form-control" autocomplete="username" placeholder="Email" />
                    <label asp-for="Input.Email">Email</label>
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>

                <div class="form-floating mb-4">
                    <input asp-for="Input.Cuit" class="form-control" placeholder="CUIT" />
                    <label asp-for="Input.Cuit">CUIT</label>
                    <span asp-validation-for="Input.Cuit" class="text-danger"></span>
                </div>

                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-primary">Enviar enlace de recuperación</button>
                    <a asp-page="./Login" class="btn btn-secondary">Volver al login</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
