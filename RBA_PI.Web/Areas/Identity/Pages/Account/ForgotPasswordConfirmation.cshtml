@page
@model ForgotPasswordConfirmation
@{
    Layout = "/Views/Shared/_LayoutEmpty.cshtml";
    ViewData["Title"] = "Correo enviado";
}

<div class="d-flex justify-content-center align-items-center vh-100">
    <div class="card shadow-lg identity-card" style="max-width: 420px;">
        <div class="card-body p-4 text-center">
            <i class="bi bi-envelope-check-fill text-success" style="font-size: 3rem;"></i>
            <h4 class="mt-3 mb-3">Revisá tu correo</h4>

            <p class="mb-3">
                Te enviamos un email con el enlace para restablecer tu contraseña.
            </p>

            <p class="text-muted small mb-4">
                Si no lo encontrás, revisá la carpeta de <strong>Spam</strong> o
                <strong>Correo no deseado</strong>.
            </p>

            <div class="d-grid gap-2">
                <a asp-page="./Login" class="btn btn-primary">Volver al login</a>
            </div>
        </div>
    </div>
</div>
